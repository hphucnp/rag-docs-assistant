# PostgreSQL
POSTGRES_USER=rag_user
POSTGRES_PASSWORD=rag_password
POSTGRES_DB=rag_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Constructed by app/config.py — override if needed
# DATABASE_URL=postgresql+asyncpg://rag_user:rag_password@localhost:5432/rag_db

# Providers
EMBEDDING_PROVIDER=ollama
CHAT_PROVIDER=groq

# Ollama
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1

# Cohere
COHERE_API_KEY=...
COHERE_BASE_URL=https://api.cohere.com/v2

# Embedding
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=1536

# LLM
GROQ_API_KEY=gsk_...
GROQ_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.1-8b-instant

# MinIO
MINIO_HOST=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=rag_minio_user
MINIO_SECRET_KEY=rag_minio_secret
MINIO_BUCKET=rag-documents
MINIO_SECURE=false
MAX_UPLOAD_SIZE_MB=10

# App
APP_ENV=development
LOG_LEVEL=INFO
# Comma-separated list of origins allowed to call the API via browsers
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:5173,https://rag.beestack.vn

# GitHub webhook (disabled by default)
GITHUB_WEBHOOK_ENABLED=false
# Set this to your GitHub webhook secret in production
GITHUB_WEBHOOK_SECRET=
# Absolute or relative path to the git repository that should be pulled
GITHUB_WEBHOOK_REPO_PATH=.
# Only process push events to this branch
GITHUB_WEBHOOK_BRANCH=main

# Caddy HTTPS (required in production)
# Example:
# FRONTEND_DOMAIN=rag.example.com
# API_DOMAIN=api.example.com
FRONTEND_DOMAIN=rag.example.com
API_DOMAIN=api.example.com
ACME_EMAIL=you@example.com
