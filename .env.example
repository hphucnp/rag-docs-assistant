# PostgreSQL
POSTGRES_USER=rag_user
POSTGRES_PASSWORD=rag_password
POSTGRES_DB=rag_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Constructed by app/config.py — override if needed
# DATABASE_URL=postgresql+asyncpg://rag_user:rag_password@localhost:5432/rag_db

# Providers
EMBEDDING_PROVIDER=ollama
CHAT_PROVIDER=groq

# Ollama
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1

# Cohere
COHERE_API_KEY=...
COHERE_BASE_URL=https://api.cohere.com/v2

# Embedding
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=1536

# LLM
GROQ_API_KEY=gsk_...
GROQ_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.1-8b-instant

# MinIO
MINIO_HOST=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=rag_minio_user
MINIO_SECRET_KEY=rag_minio_secret
MINIO_BUCKET=rag-documents
MINIO_SECURE=false
MAX_UPLOAD_SIZE_MB=10

# App
APP_ENV=development
LOG_LEVEL=INFO
